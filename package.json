{
  "name": "@fixy/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
